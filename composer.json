{
    "name": "jarvis/core",
    "description": "Jarvis Core - Cloud backend platform",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.4",
        "firebase/php-jwt": "^7.0",
        "monolog/monolog": "^3.9",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helpers/env.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "migrate": "php database/migrate.php",
        "serve": "php -S localhost:8080 -t public",
        "serve:vercel": "php -S localhost:8080 api/index.php",
        "vercel": [
            "composer install --no-dev --optimize-autoloader"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
