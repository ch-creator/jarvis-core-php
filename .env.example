APP_NAME="Jarvis Core"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=UTC

DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jarvis
DB_USERNAME=root
DB_PASSWORD=
DB_SQLITE_PATH=storage/database/jarvis.sqlite

JWT_SECRET=change-this-to-a-long-random-secret-key
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800

LOG_CHANNEL=single
LOG_LEVEL=debug
